# GlowStock server environment variables
# Copy this file to .env and fill in your values.
# The server reads these via process.env — no dotenv package is needed.

# Port the server listens on (default: 3000)
PORT=3000

# Absolute path to the SQLite database file
# Default: <server-dir>/glowstock.db
# DB_PATH=/var/data/glowstock.db

# Restrict CORS to a specific origin in production
# Default: * (allows all origins)
# ALLOWED_ORIGIN=https://yourdomain.com
